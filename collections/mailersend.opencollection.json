      "info": {
        "name": "Email",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Send an email",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.mailersend.com/v1/email",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Send a single transactional email. Either `text` or `html` content must be supplied."
        }
      ]
    },
    {
      "info": {
        "name": "Bulk Email",
        "type": "folder"
      },
      "items": [
